    def send_email(self, recipient_email: str, subject: str, body_html: str,
                  attachments: list = None, max_retries: int = 3) -> dict:
        """
        Отправка одного письма
        
        Возвращает:
            dict с результатом отправки
        """
        for attempt in range(max_retries):
            try:
                # Создание сообщения
                msg = MIMEMultipart('alternative')
                msg['From'] = self.sender_email
                msg['To'] = recipient_email
                msg['Subject'] = subject
                
                # Добавление HTML-тела
                html_part = MIMEText(body_html, 'html', 'utf-8')
                msg.attach(html_part)
                
                # Добавление вложений
                if attachments:
                    for filepath in attachments:
                        if isinstance(filepath, str):
                            filepath = Path(filepath)
                        
                        if filepath.exists():
                            with open(filepath, 'rb') as file:
                                part = MIMEBase('application', 'octet-stream')
                                part.set_payload(file.read())
                            
                            encoders.encode_base64(part)
                            filename = filepath.name
                            part.add_header(
                                'Content-Disposition',
                                f'attachment; filename="{filename}"'
                            )
                            msg.attach(part)
                
                # Отправка письма
                with smtplib.SMTP(self.smtp_server, self.smtp_port) as server:
                    server.starttls()
                    server.login(self.sender_email, self.sender_password)
                    server.send_message(msg)
                
                # Запись в журнал
                log_entry = {
                    'recipient': recipient_email,
                    'subject': subject,
                    'status': 'успешно',
                    'attempt': attempt + 1,
                    'attachments': [str(f) for f in attachments] if attachments else []
                }
                self.sent_log.append(log_entry)
                logger.info(f"Письмо успешно отправлено на {recipient_email}")
                
                return {'success': True, 'attempt': attempt + 1}
                
            except Exception as e:
                logger.error(f"Ошибка при отправке на {recipient_email} (попытка {attempt + 1}): {str(e)}")
                
                if attempt < max_retries - 1:
                    wait_time = 2 ** attempt
                    time.sleep(wait_time)
                else:
                    log_entry = {
                        'recipient': recipient_email,
                        'subject': subject,
                        'status': f'ошибка: {str(e)}',
                        'attempt': attempt + 1,
                        'attachments': [str(f) for f in attachments] if attachments else []
                    }
                    self.sent_log.append(log_entry)
                    return {'success': False, 'error': str(e), 'attempt': attempt + 1}
    
    def send_mass_email(self, contacts_file: Path, reports_dir: Path, 
                       is_debtor_report: bool = False) -> dict:
        """
        Массовая рассылка писем родителям
        
        Структура contacts_file:
            - ФИО_родителя
            - email
            - ребенок (ФИО студента)
        """
        try:
            # Чтение таблицы контактов
            contacts_df = pd.read_excel(contacts_file)
            
            required_columns = ['ФИО_родителя', 'email', 'ребенок']
            if not all(col in contacts_df.columns for col in required_columns):
                raise ValueError(f"В файле должны быть столбцы: {', '.join(required_columns)}")
            
            total_sent = 0
            total_failed = 0
            
            logger.info(f"Начинаю рассылку {len(contacts_df)} писем...")
            
            for idx, row in contacts_df.iterrows():
                parent_name = str(row['ФИО_родителя']).strip()
                recipient_email = str(row['email']).strip()
                student_name = str(row['ребенок']).strip()
                
                logger.info(f"[{idx + 1}/{len(contacts_df)}] Обрабатываю: {parent_name}")
                
                # Поиск отчетов для студента
                student_reports = []
                
                # Поиск файлов
                search_patterns = [
                    f"{student_name}*.xlsx",
                    f"{student_name}*.pdf",
                    f"{student_name.split()[0]}*.xlsx",  # Только фамилия
                    f"{student_name.split()[0]}*.pdf"
                ]
                
                for pattern in search_patterns:
                    import glob
                    found_files = glob.glob(str(reports_dir / pattern))
                    student_reports.extend([Path(f) for f in found_files])
                
                if not student_reports:
                    logger.warning(f"Не найдены отчеты для студента: {student_name}")
                    continue
                
                # Создание темы письма
                if is_debtor_report:
                    subject = f"⚠️ Академические задолженности - {student_name}"
                    body = self.create_debtor_email_template(parent_name, student_name)
                else:
                    subject = f"Отчет об успеваемости - {student_name}"
                    body = self.create_email_template(parent_name, student_name)
                
                # Отправка письма
                result = self.send_email(
                    recipient_email=recipient_email,
                    subject=subject,
                    body_html=body,
                    attachments=student_reports
                )
                
                if result['success']:
                    total_sent += 1
                else:
                    total_failed += 1
                
                # Задержка между отправками
                time.sleep(2)
            
            logger.info(f"Рассылка завершена! Успешно: {total_sent}, Неудачно: {total_failed}")
            
            return {'total_sent': total_sent, 'total_failed': total_failed}
            
        except Exception as e:
            logger.error(f"Ошибка при массовой рассылке: {str(e)}")
            raise