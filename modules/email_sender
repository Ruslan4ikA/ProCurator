        self.sent_log = []
    
    def _load_template(self, template_name: str) -> str:
        """Загрузка шаблона письма"""
        template_path = TEMPLATES_DIR / template_name
        if template_path.exists():
            with open(template_path, 'r', encoding='utf-8') as f:
                return f.read()
        return None
    
